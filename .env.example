# ── HiveMQ ───────────────────────────────────────────────────────
MQTT_BROKER=your_cluster.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_TOPIC=solar/#
MQTT_USER=your_subscriber_username
MQTT_PASSWORD=your_subscriber_password
MQTT_PUBLISHER_USER=your_publisher_username
MQTT_PUBLISHER_PASSWORD=your_publisher_password

# ── InfluxDB ──────────────────────────────────────────────────────
INFLUX_URL=https://your-region.aws.cloud2.influxdata.com
INFLUX_TOKEN=your_influxdb_token
INFLUX_ORG=your_org_name
INFLUX_BUCKET=solar_data

# ── OpenWeatherMap ────────────────────────────────────────────────
OPENWEATHER_API_KEY=your_openweathermap_api_key

# ── FastAPI ───────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=your_secret_api_key
