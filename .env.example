# ── HiveMQ ───────────────────────────────────────────────────────
MQTT_BROKER=your_cluster.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_TOPIC=solar/#
MQTT_USER=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password

# ── InfluxDB ──────────────────────────────────────────────────────
INFLUX_URL=https://your-region.aws.cloud2.influxdata.com
INFLUX_TOKEN=your_influxdb_token
INFLUX_ORG=your_org_name
INFLUX_BUCKET=solar_data

# ── OpenWeatherMap ────────────────────────────────────────────────
OPENWEATHER_API_KEY=your_openweathermap_api_key

# ── Home configuration ────────────────────────────────────────────
HOME_ID=home1
HOME_LAT=4.8156
HOME_LON=7.0498
BATTERY_TYPE=LEAD_ACID
NOMINAL_VOLTAGE=12V
BATTERY_CAPACITY_WH=100
